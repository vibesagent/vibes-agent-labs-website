{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vibes-agent-labs-website",
  "compatibility_date": "2026-03-12",
  "routes": [
    {
      "pattern": "vibesagent.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
